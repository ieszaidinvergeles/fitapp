# ─── APPLICATION ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_KEY=                        # php artisan key:generate --show
APP_URL=http://YOUR_SERVER_IP   # e.g. http://192.168.1.100

# ─── DATABASE ─────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_this_root_password
DB_DATABASE=voltgym
DB_USERNAME=voltgym_user
DB_PASSWORD=change_this_db_password

# ─── WORDPRESS DATABASE ───────────────────────────────────────────────────────
# WordPress gets its own DB inside the same MySQL instance
WP_DB_NAME=voltgym_wordpress

# ─── REPOSITORY ───────────────────────────────────────────────────────────────
REPO_URL=https://github.com/YOUR_USER/YOUR_REPO.git
REPO_BRANCH=main
